# Copy to .env.production and set the real value. `.env.production` is gitignored.
# Vite picks this file up automatically during `npm run build`.
# Full origin of the parley-room backend (no trailing slash); the client appends /api/v1.
# Used later by Phase B to POST /api/v1/token/telegram-miniapp.
VITE_API_BASE_URL=https://api.your-backend.example.com
